{
    "name": "php-skir/server",
    "description": "Laravel SkirRPC server package.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "php",
        "rpc",
        "serialization",
        "skir"
    ],
    "homepage": "https://github.com/php-skir/server",
    "support": {
        "issues": "https://github.com/php-skir/server/issues",
        "source": "https://github.com/php-skir/server"
    },
    "authors": [
        {
            "name": "Maxim Kerstens",
            "email": "maxim.kerstens@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "nikic/php-parser": "^5.8",
        "php-skir/runtime": "^0.1@dev",
        "symfony/process": "^7.4|^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.0",
        "php-skir/client": "^0.1@dev",
        "phpunit/phpunit": "^12.5",
        "spomky-labs/cbor-php": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Skir\\Server\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Skir\\Server\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../runtime",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../client",
            "options": {
                "symlink": false
            }
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Skir\\Server\\SkirServerServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "scripts": {
        "format": "pint",
        "test": "phpunit"
    },
    "suggest": {
        "spomky-labs/cbor-php": "Required when using SkirCodecs::cbor() for application/cbor endpoints."
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
